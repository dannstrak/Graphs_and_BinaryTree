--- a/src/logic/map_Graph.py	(revision bfaabdcd273c5752fb7a8f8e82f85540edae524d)
+++ b/src/logic/map_Graph.py	(date 1783227289522)
@@ -1,0 +1,47 @@
+class Habitacion:
+    def __init__(self, id_hab, nombre, descripcion, recompensa_nombre=None, recompensa_poder=0):
+        self.id_hab = id_hab
+        self.nombre = nombre
+        self.descripcion = descripcion
+        self.recompensa_nombre = recompensa_nombre
+        self.recompensa_poder = recompensa_poder
+
+        self.puertas = {}
+    def agregar_puerta(self, id_destino, descripcion_opcion):
+        self.puertas[id_destino] = descripcion_opcion
+
+
+
+
+class map_Graph:
+    def __init__(self):
+        self.habitaciones = {}
+
+    def agregarHabitacion(self, habitacion):
+        self.habitaciones[habitacion.id_hab] = habitacion
+
+    if __name__ == '__main__':
+        mapa = map_Graph()
+        hab_inicio = Habitacion("INICIO", "Entrada a la Mazmorra", "Frente a ti hay dos pasillos oscuros.")
+        hab_izq = Habitacion("IZQ", "Sala del Fuego", "El calor es insoportable.", "Espada de Fuego", 50)
+        hab_der = Habitacion("DER", "Cueva del Duende", "Escuchas risas macabras.", "Escudo de Madera", 15)
+        hab_jefe = Habitacion("JEFE", "Guarida del Dragón", "El jefe final te espera.")
+
+        # 3. Crear las aristas (Conectar con agregar_puerta)
+        hab_inicio.agregar_puerta("IZQ", "Ir por el pasillo izquierdo (Huele a quemado)")
+        hab_inicio.agregar_puerta("DER", "Ir por el pasillo derecho (Hay huellas en el suelo)")
+
+        hab_izq.agregar_puerta("JEFE", "Abrir la gran puerta de obsidiana")
+        hab_der.agregar_puerta("JEFE", "Bajar por las escaleras caracol")
+
+        # 4. Guardar los nodos en el grafo
+        mapa.agregar_habitacion(hab_inicio)
+        mapa.agregar_habitacion(hab_izq)
+        mapa.agregar_habitacion(hab_der)
+        mapa.agregar_habitacion(hab_jefe)
+
+        # 5. Probar que la estructura funciona
+        inicio = mapa.habitaciones["INICIO"]
+        print(f"--- {inicio.nombre} ---")
+        for destino, opcion in inicio.puertas.items():
+            print(f"Opción: {opcion} -> Te lleva a: {destino}")
\ No newline at end of file
